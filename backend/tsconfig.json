{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@catan/core": ["../packages/catan-core/src"],
      "@catan/core/*": ["../packages/catan-core/src/*"]
    }
  },
  "include": ["src"]
}
